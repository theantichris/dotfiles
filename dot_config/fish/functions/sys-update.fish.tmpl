function __su_banner
    set_color $cyberpunk_primary
    echo '  ╔══════════════════════════════════════════════════╗'
    echo -n '  ║  '
    set_color -o $cyberpunk_secondary
    echo -n 'System Update'
    set_color normal
    set_color $cyberpunk_primary
    echo '                                   ║'
    echo '  ╚══════════════════════════════════════════════════╝'
    set_color normal
end

# __su_step <label> <cmd...> — prints a styled header, runs cmd, reports status
function __su_step
    set -l label $argv[1]
    set -l cmd $argv[2..-1]

    set -g __su_n (math $__su_n + 1)
    set -l tag (printf '%02d' $__su_n)

    echo ''
    set_color $cyberpunk_comment
    echo -n '  ▓▒░ '
    set_color -o $cyberpunk_tertiary
    echo -n "[$tag] "
    set_color -o $cyberpunk_secondary
    echo -n "$label"
    set_color normal
    set_color $cyberpunk_comment
    echo ' ░▒▓'
    set_color $cyberpunk_warning
    echo "  \$ $cmd"
    set_color normal

    set -l t0 (date +%s)
    $cmd
    set -l code $status
    set -l dt (math (date +%s) - $t0)

    if test $code -eq 0
        set_color -o $cyberpunk_success
        echo "  ✔ done"(set_color normal)(set_color $cyberpunk_comment)"  ·  "$label"  ·  "$dt"s"
    else
        set_color -o $cyberpunk_error
        echo "  ✘ failed (exit $code)"(set_color normal)(set_color $cyberpunk_comment)"  ·  "$label"  ·  "$dt"s"
    end
    set_color normal
    return $code
end

function sys-update
    set -g __su_n 0
    set -l __su_start (date +%s)
    __su_banner

    {{- if eq .chezmoi.os "darwin" }}
    __su_step 'Homebrew sync' brew update
    __su_step 'Homebrew upgrade' brew upgrade
    {{- else if eq .chezmoi.os "android" }}
    __su_step 'Termux sync' pkg update
    __su_step 'Termux upgrade' pkg upgrade
    __su_step 'Termux autoclean' pkg autoclean
    __su_step 'Claude Code' claude --update-now
    {{- else }}
    __su_step 'CachyOS system' cachy-update
    __su_step 'Shelly packages' shelly upgrade-all
    {{- end }}
    __su_step 'Go binaries' go-global-update
    __su_step 'Rust crates' cargo install-update -a
    __su_step 'gh extensions' gh extension upgrade --all

    set -l __su_total (math (date +%s) - $__su_start)
    echo ''
    set_color -o $cyberpunk_success
    echo -n '  ◆ ALL SYSTEMS PATCHED'
    set_color normal
    set_color $cyberpunk_comment
    echo "  //  $__su_n tasks  ·  "$__su_total"s elapsed"
    set_color normal
end
