[color]
ui = auto

[color "status"]
header    = "#8A86A0"
added     = "#00FFA2"
changed   = "#FFD300"
untracked = "#FF00FF"
branch    = "#00F0FF bold"
nobranch  = "#FF003C bold"
unmerged  = "#FF003C"

[color "branch"]
current  = "#00F0FF bold"
local    = "#EAEAF2"
remote   = "#FF00FF"
upstream = "#CA0174"
plain    = "#EAEAF2"

[color "decorate"]
branch       = "#00F0FF bold"
remoteBranch = "#FF00FF"
tag          = "#FFD300"
HEAD         = "#CA0174 bold"
stash        = "#8A86A0"

[color "interactive"]
prompt = "#00F0FF"
header = "#CA0174 bold"
help   = "#8A86A0"
error  = "#FF003C bold"

[color "remote"]
hint    = "#8A86A0"
warning = "#FFD300"
success = "#00FFA2"
error   = "#FF003C bold"

[commit]
gpgsign = true

[core]
editor = {{ if eq .chezmoi.os "darwin" }}hx{{ else }}helix{{ end }}
excludesFile = .gitignore
autocrlf = input
eol = lf
safecrlf = false
pager = delta

[delta]
navigate = true
dark = true
syntax-theme = cyberpunk
line-numbers = true
hyperlinks = true
# diff body: keep syntax highlighting, tint line backgrounds
# added = palette green (#00FFA2), removed = palette magenta (#FF00FF), blended over base #16161E
plus-style = syntax "#133932"
plus-emph-style = syntax "#0F5C46"
minus-style = syntax "#391340"
minus-emph-style = syntax "#5C0F62"
zero-style = syntax
whitespace-error-style = "#FF003C reverse"
# gutter line numbers
line-numbers-left-style = "#8A86A0"
line-numbers-right-style = "#8A86A0"
line-numbers-minus-style = "#FF00FF"
line-numbers-plus-style = "#00FFA2"
line-numbers-zero-style = "#8A86A0"
# file + hunk headers
file-style = "#00F0FF bold"
file-decoration-style = "#CA0174 ul"
hunk-header-style = "#FF00FF bold"
hunk-header-decoration-style = "#00F0FF box"
hunk-header-line-number-style = "#FFD300"
# commit + blame accents
commit-style = "#FFD300 bold"
commit-decoration-style = "#CA0174 ul"
blame-palette = "#133039" "#321339" "#13302E" "#132639"

[diff]
tool = code

[gpg]
format = openpgp

[init]
defaultBranch = main

[interactive]
diffFilter = delta --color-only

[merge]
conflictstyle = zdiff3

[pull]
rebase = true

[push]
default = simple

