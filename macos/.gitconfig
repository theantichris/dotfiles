# This is Git's per-user configuration file.
[user]
	signingkey = 2CE91E1CAABF463E2276DD6DDD034D4167580AC2
	name = Christopher Lamm
	email = christopherlamm@theartofeducation.edu
[commit]
	gpgsign = true
[rerere]
	enabled = true
[pull]
	rebase = true
[core]
	excludesfile = /Users/christopherlamm/.gitignore
	editor = nano
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = main
[pager]
	branch = false
