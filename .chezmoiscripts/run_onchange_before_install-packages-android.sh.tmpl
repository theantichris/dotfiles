{{- if eq .chezmoi.os "android" -}}
#!/data/data/com.termux/files/usr/bin/bash

# PKG

pkg install bat
pkg install cmatrix
pkg install curl
pkg install eza
pkg install fastfetch
pkg install fd
pkg install fish
pkg install fzf
pkg install gh
pkg install git
pkg install git-delta
pkg install glow
pkg install golang
pkg install helix lua-language-server marksman
pkg install jq
pkg install newsboat
pkg install openssh
pkg install ripgrep
pkg install termux-api
pkg install termux-services
pkg install speedtest-go
pkg install tealdeer
pkg install which

# GO
go install github.com/Gelio/go-global-update@latest
go install github.com/SourcewareLab/Toney/v2@latest
go install github.com/theantichris/ghost/v3@latest
go install golang.org/x/tools/cmd/goimports@latest
go install github.com/yorukot/superfile@latest

# RUST
cargo install cargo-update

# CLAUDE CODE
if ! command -v claude >/dev/null 2>&1; then
    ferrum_ref=617d8a45bacbe3c44441ce3cd3ec40f7b978cce0
    curl -fsSL "https://raw.githubusercontent.com/ferrumclaudepilgrim/claude-code-android/$ferrum_ref/install.sh" -o "$TMPDIR/ferrum-claude-install.sh"
    bash "$TMPDIR/ferrum-claude-install.sh"
    rm -f "$TMPDIR/ferrum-claude-install.sh"
fi

bat cache --build
tldr --update

command -v termux-reload-settings >/dev/null && termux-reload-settings

{{- end }}

