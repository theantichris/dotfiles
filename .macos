#!/usr/bin/env bash

# ~/.macos — https://mths.be/macos
# Modified by Christopher Lamm
# Run without downloading:
# curl https://raw.githubusercontent.com/theantichirs/dotfiles/master/.macos | bash

# Close System Preferences panes
osascript -e 'tell application "System Preferences" to quit'

# Ask for the administrator password upfront
sudo -v

# Keep-alive: update existing `sudo` time stamp until `.macos` has finished
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

################################################################################
# Create Directories                                                           #
################################################################################

echo "Making ${HOME}/Code directory..."
mkdir -p "${HOME}/Code"
mkdir -p "${HOME}/Code/AOEU"
mkdir -p "${HOME}/Code/Personal"
mkdir -p "${HOME}/Code/Vendor"

################################################################################
# HomeBrew                                                                     #
################################################################################

# Install Homebrew
echo "Installing Homebrew..."
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"

# Turn off Homebrew analytics
echo "Turnning off analytics..."
export HOMEBREW_NO_ANALYTICS=1
brew analytics off

# Install Homebrew packages
echo "Installing packages..."
brew tap heroku/brew
brew install act bat gh golang heroku tree

# Install Homebrew Cask packages
echo "Installing Casks..."
brew tap homebrew/cask-fonts
homebrew install --cask 1password alfred clickup discord docker font-fira-code \
google-chrome google-drive-file-stream gpg-suite iterm2 miro rectangle slack \
tweetbot visual-studio-code zoom

################################################################################
# Node                                                                         #
################################################################################

# Install Node via nvm
echo "Installing nvm..."
curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.37.2/install.sh | bash
echo "Installing Node..."
nvm install node

# Install global NPM packages
echo "Installing global NPM packages..."
npm install --global fast-cli trash-cli

################################################################################
# RSA                                                                          #
################################################################################

# Generate RSA token
echo "Generating RSA token..."
mkdir -p ~/.ssh
touch ~/.ssh/config
ssh-keygen -t ed25519 -C "chris@theantichris.com"
echo "Host *\n AddKeysToAgent yes\n IdentityFile ~/.ssh/id_ed25519" | tee ~/.ssh/config
eval "$(ssh-agent -s)"
ssh-add -K ~/.ssh/id_ed25519
echo "run 'pbcopy < ~/.ssh/id_ed25519.pub' and paste that into GitHub"

################################################################################
# ohmyzsh                                                                      #
################################################################################

# Install ohmyzsh
echo "Installing ohmyzsh..."
sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

echo "Cloning plugins..."
git clone https://github.com/zsh-users/zsh-autosuggestions ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions
git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting
git clone https://github.com/davidde/git.git ~/.oh-my-zsh/custom/plugins/git

echo "Installing powerlevel10k..."
brew install romkatv/powerlevel10k/powerlevel10k

################################################################################
# dotfiles                                                                     #
################################################################################

# Clone dotfiles
echo "Cloning dotfiles..."
git clone git@github.com:theantichris/dotfiles.git "${HOME}/dotfiles"

echo "Setting up symlinks..."
ln -s "${HOME}/dotfiles/.zshrc" "${HOME}/.zshrc"
ln -s "${HOME}/dotfiles/.gitignore" "${HOME}/.gitignore"
ln -s "${HOME}/dotfiles/.gitconfig" "${HOME}/.gitconfig"

################################################################################
# MacOS                                                                        #
################################################################################

# Disable the “Are you sure you want to open this application?” dialog
defaults write com.apple.LaunchServices LSQuarantine -bool false

################################################################################
# MacOS - Dock                                                                 #
################################################################################

# Set the icon size of Dock items to 16 pixels
defaults write com.apple.dock tilesize -int 16

# Minimize windows into their application’s icon
defaults write com.apple.dock minimize-to-application -bool true

# Wipe all (default) app icons from the Dock
defaults write com.apple.dock persistent-apps -array

# Automatically hide and show the Dock
defaults write com.apple.dock autohide -bool true

################################################################################
# MacOS - Printers & Scanners                                                  #
################################################################################

# Automatically quit printer app once the print jobs complete
defaults write com.apple.print.PrintingPrefs "Quit When Finished" -bool true

################################################################################
# MacOS - Notification Center                                                  #
################################################################################

# Disable Notification Center and remove the menu bar icon
launchctl unload -w /System/Library/LaunchAgents/com.apple.notificationcenterui.plist 2> /dev/null

################################################################################
# MacOS - Trackpad                                                             #
################################################################################

# Enable tap to click for this user and for the login screen
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
defaults -currentHost write NSGlobalDomain com.apple.mouse.tapBehavior -int 1
defaults write NSGlobalDomain com.apple.mouse.tapBehavior -int 1

################################################################################
# MacOS - Bluetooth                                                            #
################################################################################

# Increase sound quality for Bluetooth headphones/headsets
defaults write com.apple.BluetoothAudioAgent "Apple Bitpool Min (editable)" -int 40

################################################################################
# MacOS - Security & Privacy                                                   #
################################################################################

# Require password immediately after sleep or screen saver begins
defaults write com.apple.screensaver askForPassword -int 1
defaults write com.apple.screensaver askForPasswordDelay -int 0

################################################################################
# MacOS - Screenshots                                                          #
################################################################################

# Save screenshots to the Downloads folder
defaults write com.apple.screencapture location -string "${HOME}/Downloads"

# Save screenshots in PNG format (other options: BMP, GIF, JPG, PDF, TIFF)
defaults write com.apple.screencapture type -string "png"

################################################################################
# MacOS - Finder                                                               #
################################################################################

# Show icons for hard drives, servers, and removable media on the desktop
defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool false
defaults write com.apple.finder ShowHardDrivesOnDesktop -bool false
defaults write com.apple.finder ShowMountedServersOnDesktop -bool false
defaults write com.apple.finder ShowRemovableMediaOnDesktop -bool false

# Show all filename extensions
defaults write NSGlobalDomain AppleShowAllExtensions -bool true

# Show status bar
defaults write com.apple.finder ShowStatusBar -bool true

# Show path bar
defaults write com.apple.finder ShowPathbar -bool true

# Keep folders on top when sorting by name
defaults write com.apple.finder _FXSortFoldersFirst -bool true

################################################################################
# MacOS - Safari                                                               #
################################################################################

# Privacy: don’t send search queries to Apple
defaults write com.apple.Safari UniversalSearchEnabled -bool false
defaults write com.apple.Safari SuppressSearchSuggestions -bool true

# Prevent Safari from opening ‘safe’ files automatically after downloading
defaults write com.apple.Safari AutoOpenSafeDownloads -bool false
