# This is Git's per-user configuration file.
[user]
	signingkey = F031BEB4EBCA00CB4BE7D2E5D3ED9D7466CE72E2
	name = Christopher Lamm
	email = chris@theantichris.com
[commit]
	gpgsign = true
[rerere]
	enabled = true
[pull]
	rebase = true
[core]
	excludesfile = /Users/christopherlamm/.gitignore
	editor = nano
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = main
